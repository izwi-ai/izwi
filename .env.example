# =============================================================================
# Izwi Audio - Environment Variables
# =============================================================================
# Copy this file to .env and adjust as needed

# Server Configuration
IZWI_HOST=0.0.0.0
IZWI_PORT=8080
IZWI_BACKEND=auto
IZWI_MAX_BATCH_SIZE=8
IZWI_NUM_THREADS=8
IZWI_MAX_CONCURRENT=100
IZWI_TIMEOUT=300
IZWI_CORS=0
# IZWI_CORS_ORIGINS=http://localhost:3000,https://example.com
IZWI_NO_UI=0
IZWI_UI_DIR=ui/dist

# Legacy compatibility aliases (prefer the canonical names above)
# MAX_CONCURRENT_REQUESTS=100
# REQUEST_TIMEOUT_SECS=300

# HuggingFace Configuration
# Set your HuggingFace token for private models (optional)
# HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxx

# Model Storage
# HF_HOME=/app/models/huggingface
# TRANSFORMERS_CACHE=/app/models/huggingface

# Logging
RUST_LOG=info
PYTHONUNBUFFERED=1

# CUDA Configuration (for GPU builds)
# NVIDIA_VISIBLE_DEVICES=all
# CUDA_VISIBLE_DEVICES=0
