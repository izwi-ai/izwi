{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Izwi",
  "description": "Local-first audio inference documentation for text-to-speech, transcription, diarization, chat, and voice AI workflows.",
  "colors": {
    "primary": "#B83A2F",
    "light": "#D95545",
    "dark": "#DF5146"
  },
  "logo": {
    "light": "/images/app-icon.png",
    "dark": "/images/app-icon.png",
    "href": "/"
  },
  "favicon": "/images/app-icon.png",
  "appearance": {
    "default": "system"
  },
  "icons": {
    "library": "lucide"
  },
  "styling": {
    "eyebrows": "breadcrumbs",
    "codeblocks": "system"
  },
  "metadata": {
    "timestamp": true
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/izwi-ai/izwi"
      }
    ],
    "primary": {
      "type": "button",
      "label": "Get started",
      "href": "/getting-started"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/izwi-ai/izwi"
    }
  },
  "api": {
    "playground": {
      "display": "none"
    }
  },
  "navigation": {
    "directory": "card",
    "groups": [
      {
        "group": "Home",
        "icon": "house",
        "pages": [
          "index",
          "getting-started",
          "support-matrix"
        ]
      },
      {
        "group": "Installation",
        "icon": "download",
        "root": "installation/index",
        "pages": [
          "installation/macos",
          "installation/linux",
          "installation/windows",
          "installation/from-source"
        ]
      },
      {
        "group": "Features",
        "icon": "sparkles",
        "root": "features/index",
        "pages": [
          "features/voice",
          "features/chat",
          "features/transcription",
          "features/speaker-attributed-asr",
          "features/voices",
          "features/text-to-speech",
          "features/studio",
          "features/settings",
          "features/diarization",
          "features/voice-cloning",
          "features/voice-design"
        ]
      },
      {
        "group": "CLI Reference",
        "icon": "terminal",
        "root": "cli/index",
        "pages": [
          {
            "group": "Server",
            "pages": [
              "cli/serve",
              "cli/status",
              "cli/config",
              "cli/version",
              "cli/completions"
            ]
          },
          {
            "group": "Models",
            "pages": [
              "cli/list",
              "cli/pull",
              "cli/rm",
              "cli/models"
            ]
          },
          {
            "group": "Workflows",
            "pages": [
              "cli/tts",
              "cli/transcribe",
              "cli/diarize",
              "cli/align",
              "cli/chat"
            ]
          },
          {
            "group": "Benchmarks",
            "pages": [
              "cli/bench"
            ]
          }
        ]
      },
      {
        "group": "Models",
        "icon": "database",
        "root": "models/index",
        "pages": [
          "models/management",
          "models/voice-presets",
          "models/manual-download",
          "models/manual-gemma-3-1b-download"
        ]
      },
      {
        "group": "Reference & Help",
        "icon": "book-open",
        "pages": [
          "api",
          "troubleshooting"
        ]
      }
    ]
  },
  "redirects": [
    {
      "source": "/manual-gemma-3-1b-download",
      "destination": "/models/manual-gemma-3-1b-download",
      "permanent": true
    },
    {
      "source": "/features/voice-studio",
      "destination": "/features/voices",
      "permanent": true
    }
  ],
  "errors": {
    "404": {
      "title": "Page not found",
      "description": "The page may have moved. Use the sidebar or search to find the current Izwi docs."
    }
  }
}
